{
  "name": "web_yanchuaner",
  "private": true,
  "version": "2.0.0",
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "prisma generate && next build",
    "start": "next start -H 0.0.0.0",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test:mp-auth": "tsx --test scripts/mp-auth-contract.test.ts",
    "test:mp-contract": "tsx --test scripts/mp-contract.test.ts",
    "test:web-auth": "tsx --test scripts/web-account-state.test.ts",
    "test:acceptance": "node scripts/acceptance-smoke.js",
    "seed:acceptance": "tsx scripts/seed_acceptance.ts",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "audit:images": "node scripts/audit_images.js",
    "audit:ui-tokens": "node scripts/audit_ui_tokens.js",
    "build:check:wsl": "wsl.exe bash /mnt/c/Dev/yanchuaner/web_yanchuaner/scripts/validate_build_wsl.sh",
    "fresh": "bash scripts/clean.sh && npm run dev",
    "update-list": "node scripts/build_list.js",
    "create-admin": "tsx scripts/create_admin.ts",
    "normalize-identity-fields": "node scripts/normalize_identity_fields.js",
    "migrate-users": "tsx scripts/migrate_users.ts",
    "smoke": "node scripts/smoke-test.js",
    "release:check": "npm run db:generate && npx tsc --noEmit && npm run lint && npm run test:web-auth && npm run test:mp-auth && npm run test:mp-contract && npm run audit:ui-tokens && npm run audit:prod",
    "seed": "tsx prisma/seed.ts",
    "seed-all": "npm run seed && node scripts/seed_content_sections.js && node scripts/seed_memories.js",
    "db:generate": "prisma generate",
    "db:init": "node scripts/init_sqlite_db.js && prisma migrate deploy",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "npm run seed-all"
  },
  "dependencies": {
    "@faker-js/faker": "^10.5.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/leaflet": "^1.9.21",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "12.9.0",
    "dotenv": "^17.4.2",
    "fuse.js": "^7.3.0",
    "ioredis": "^5.10.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.542.0",
    "next": "15.5.19",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-leaflet": "^4.2.1",
    "resend": "^4.8.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.17.57",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.19",
    "postcss": "^8.5.6",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "@hono/node-server": "2.0.6",
    "hono": "4.12.27"
  }
}
