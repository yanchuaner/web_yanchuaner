// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                     String             @id @default(uuid())
  username               String?            @unique
  passwordHash           String?
  email                  String?            @unique
  emailVerified          DateTime?
  emailVerifyTokenHash   String?
  emailVerifyExpiresAt   DateTime?
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  name                   String?
  contact                String?
  identityCode           String?
  graduationClass        String?
  className              String?
  city                   String?
  university             String?
  major                  String?
  industry               String?
  role                   String             @default("GUEST")
  status                 String             @default("PENDING")
  accountStatus          String             @default("ACTIVE")
  sessionVersion         Int                @default(0)
  claimedAt              DateTime?
  mergedIntoUserId       String?
  mergedIntoUser         User?              @relation("UserMerged", fields: [mergedIntoUserId], references: [id])
  mergedUsers            User[]             @relation("UserMerged")
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  posts                  Post[]
  stories                Story[]            @relation("StoryAuthor")
  auditLogs              AuditLog[]         @relation("AuditLogAdmin")
  claimRequests          UserClaimRequest[] @relation("ClaimRequestClaimant")
  oldUserClaimRequests   UserClaimRequest[] @relation("ClaimRequestOldUser")
  reviewedClaimRequests  UserClaimRequest[] @relation("ClaimRequestReviewer")

  @@index([status])
  @@index([role])
  @@index([accountStatus])
  @@index([emailVerified])
  @@index([emailVerifyTokenHash])
  @@index([passwordResetTokenHash])
  @@index([graduationClass])
  @@index([mergedIntoUserId])
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  targetType String
  targetId   String
  adminId    String
  admin      User     @relation("AuditLogAdmin", fields: [adminId], references: [id])
  before     String?
  after      String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model UserClaimRequest {
  id             String    @id @default(uuid())
  claimantUserId String
  claimant       User      @relation("ClaimRequestClaimant", fields: [claimantUserId], references: [id])
  oldUserId      String?
  oldUser        User?     @relation("ClaimRequestOldUser", fields: [oldUserId], references: [id])
  description    String?
  status         String    @default("PENDING")
  adminNote      String?
  reviewedById   String?
  reviewedBy     User?     @relation("ClaimRequestReviewer", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([claimantUserId, status])
  @@index([oldUserId])
  @@index([status])
  @@index([reviewedById])
}

model WhitelistRoster {
  id              String   @id @default(uuid())
  name            String
  gender          String?
  graduationClass String?
  className       String?
  email           String?
  contact         String?
  city            String?
  university      String?
  major           String?
  industry        String?
  certificateNo   String?
  createdAt       DateTime @default(now())

  @@index([name])
  @@index([graduationClass])
  @@index([email])
}

model AlumniCorrectionRequest {
  id                       String    @id @default(uuid())
  rosterId                 String
  currentName              String?
  currentGraduationClass   String?
  currentClassName         String?
  currentTags              String?
  requestedName            String?
  requestedGraduationClass String?
  requestedClassName       String?
  requestedTags            String?
  requestedCity            String?
  requestedUniversity      String?
  requestedMajor           String?
  requestedIndustry        String?
  requestedContact         String?
  contact                  String
  reason                   String
  status                   String    @default("PENDING")
  adminNote                String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  reviewedAt               DateTime?

  @@index([status])
  @@index([rosterId])
}

model Post {
  id        String   @id @default(uuid())
  title     String
  content   String
  type      String
  status    String   @default("DRAFT")
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model News {
  id          String    @id @default(uuid())
  title       String
  summary     String?
  content     String
  imageUrl    String?
  status      String    @default("DRAFT")
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

model Event {
  id            String              @id @default(uuid())
  title         String
  summary       String?
  content       String
  location      String?
  eventDate     DateTime
  endDate       DateTime?
  coverImage    String?
  maxAttendees  Int?
  status        String              @default("DRAFT")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  registrations EventRegistration[]

  @@index([status])
}

model EventRegistration {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  name      String
  contact   String?
  message   String?
  createdAt DateTime @default(now())

  @@index([eventId])
  @@index([createdAt])
}

model MemoryItem {
  id          String   @id @default(uuid())
  title       String
  subtitle    String   @default("")
  description String   @default("")
  imagePath   String   @default("")
  imageAlt    String   @default("")
  icon        String   @default("camera")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TeacherSection {
  id          String   @id @default(uuid())
  title       String
  description String   @default("")
  note        String   @default("")
  icon        String   @default("BookOpen")
  href        String?
  actionLabel String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContentSection {
  id          String   @id @default(uuid())
  page        String // "about_features", "about_timeline", "contact", "students"
  title       String
  description String   @default("")
  note        String   @default("")
  icon        String   @default("BookOpen")
  href        String?
  actionLabel String?
  yearLabel   String? // 时间线年份 (仅 about_timeline)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([page])
}

enum PostStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
}

model Story {
  id         String     @id @default(uuid())
  title      String
  author     String
  tags       String     @default("") // JSON array as string
  body       String     @default("")
  date       String     @default("") // ISO date string
  status     PostStatus @default(PUBLISHED)
  authorId   String?
  authorUser User?      @relation("StoryAuthor", fields: [authorId], references: [id])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([status])
  @@index([authorId])
}

model Achievement {
  id              String   @id @default(uuid())
  alumniName      String
  graduationClass String?
  title           String
  category        String   @default("OTHER")
  description     String   @default("")
  organization    String?
  yearLabel       String?
  status          String   @default("DRAFT")
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@index([sortOrder])
}
