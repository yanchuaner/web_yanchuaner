// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                           String                        @id @default(uuid())
  username                     String?                       @unique
  passwordHash                 String?
  email                        String?                       @unique
  emailVerified                DateTime?
  emailVerifyTokenHash         String?
  emailVerifyExpiresAt         DateTime?
  passwordResetTokenHash       String?
  passwordResetExpiresAt       DateTime?
  name                         String?
  contact                      String?
  identityCode                 String?
  graduationClass              String?
  className                    String?
  city                         String?
  university                   String?
  major                        String?
  industry                     String?
  verificationStatus           VerificationStatus            @default(NOT_SUBMITTED)
  verificationMethod           VerificationMethod?
  identityType                 IdentityType?
  teacherPosition              String?
  contactVisibility            ContactVisibility             @default(PRIVATE)
  role                         String                        @default("GUEST")
  status                       String                        @default("PENDING")
  accountStatus                String                        @default("ACTIVE")
  sessionVersion               Int                           @default(0)
  claimedAt                    DateTime?
  mergedIntoUserId             String?
  mergedIntoUser               User?                         @relation("UserMerged", fields: [mergedIntoUserId], references: [id])
  mergedUsers                  User[]                        @relation("UserMerged")
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  posts                        Post[]
  stories                      Story[]                       @relation("StoryAuthor")
  auditLogs                    AuditLog[]                    @relation("AuditLogAdmin")
  wechatIdentities             WechatIdentity[]
  verificationRequests         IdentityVerificationRequest[] @relation("VerificationApplicant")
  reviewedVerificationRequests IdentityVerificationRequest[] @relation("VerificationReviewer")
  eventRegistrations           EventRegistration[]

  @@index([status])
  @@index([role])
  @@index([accountStatus])
  @@index([emailVerified])
  @@index([emailVerifyTokenHash])
  @@index([passwordResetTokenHash])
  @@index([graduationClass])
  @@index([mergedIntoUserId])
  @@index([verificationStatus])
  @@index([identityType])
}

model WechatIdentity {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  appId       String
  openid      String
  unionid     String?
  lastLoginAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([appId, openid])
  @@unique([userId, appId])
  @@index([userId])
  @@index([unionid])
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  targetType String
  targetId   String
  adminId    String
  admin      User     @relation("AuditLogAdmin", fields: [adminId], references: [id])
  before     String?
  after      String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model WhitelistRoster {
  id                   String                        @id @default(uuid())
  name                 String
  gender               String?
  graduationClass      String?
  className            String?
  email                String?
  contact              String?
  city                 String?
  university           String?
  major                String?
  industry             String?
  certificateNo        String?
  createdAt            DateTime                      @default(now())
  verificationRequests IdentityVerificationRequest[]

  @@index([name])
  @@index([graduationClass])
  @@index([email])
}

model IdentityVerificationRequest {
  id              String                    @id @default(uuid())
  userId          String
  user            User                      @relation("VerificationApplicant", fields: [userId], references: [id], onDelete: Cascade)
  identityType    IdentityType
  name            String
  graduationClass String?
  className       String?
  teacherPosition String?
  matchResult     VerificationMatchResult
  matchedRosterId String?
  matchedRoster   WhitelistRoster?          @relation(fields: [matchedRosterId], references: [id], onDelete: SetNull)
  status          VerificationRequestStatus @default(PENDING)
  adminNote       String?
  reviewedById    String?
  reviewedBy      User?                     @relation("VerificationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([matchedRosterId])
  @@index([reviewedById])
}

model AlumniCorrectionRequest {
  id                       String    @id @default(uuid())
  rosterId                 String
  currentName              String?
  currentGraduationClass   String?
  currentClassName         String?
  currentTags              String?
  requestedName            String?
  requestedGraduationClass String?
  requestedClassName       String?
  requestedTags            String?
  requestedCity            String?
  requestedUniversity      String?
  requestedMajor           String?
  requestedIndustry        String?
  requestedContact         String?
  contact                  String
  reason                   String
  status                   String    @default("PENDING")
  adminNote                String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  reviewedAt               DateTime?

  @@index([status])
  @@index([rosterId])
}

model Post {
  id        String   @id @default(uuid())
  title     String
  content   String
  type      String
  status    String   @default("DRAFT")
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model News {
  id          String    @id @default(uuid())
  title       String
  summary     String?
  content     String
  imageUrl    String?
  status      String    @default("DRAFT")
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

model Event {
  id            String              @id @default(uuid())
  title         String
  summary       String?
  content       String
  location      String?
  eventDate     DateTime
  endDate       DateTime?
  coverImage    String?
  maxAttendees  Int?
  status        String              @default("DRAFT")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  registrations EventRegistration[]

  @@index([status])
}

model EventRegistration {
  id          String                  @id @default(uuid())
  eventId     String
  event       Event                   @relation(fields: [eventId], references: [id])
  userId      String?
  user        User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String
  contact     String?
  message     String?
  status      EventRegistrationStatus @default(APPROVED)
  cancelledAt DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@unique([eventId, userId])
  @@index([eventId, status])
  @@index([userId, status])
  @@index([createdAt])
}

model MemoryItem {
  id          String   @id @default(uuid())
  title       String
  subtitle    String   @default("")
  description String   @default("")
  imagePath   String   @default("")
  imageAlt    String   @default("")
  icon        String   @default("camera")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TeacherSection {
  id          String   @id @default(uuid())
  title       String
  description String   @default("")
  note        String   @default("")
  icon        String   @default("BookOpen")
  href        String?
  actionLabel String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContentSection {
  id          String   @id @default(uuid())
  page        String // "about_features", "about_timeline", "contact", "students"
  title       String
  description String   @default("")
  note        String   @default("")
  icon        String   @default("BookOpen")
  href        String?
  actionLabel String?
  yearLabel   String? // 时间线年份 (仅 about_timeline)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([page])
}

enum PostStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
}

enum IdentityType {
  ALUMNI
  STUDENT
  TEACHER
}

enum VerificationStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

enum VerificationMethod {
  INTERNAL_CODE
  ADMIN_REVIEW
  IDENTITY_REVIEW
  LEGACY
}

enum VerificationRequestStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum VerificationMatchResult {
  MATCHED
  CONFLICT
  NOT_FOUND
  NOT_APPLICABLE
}

enum ContactVisibility {
  PRIVATE
  VERIFIED_USERS
}

enum EventRegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model RegistrationPolicy {
  id                String   @id @default("default")
  accessCodeHash    String?
  accessCodeHint    String   @default("")
  accessCodeEnabled Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Story {
  id         String     @id @default(uuid())
  title      String
  author     String
  tags       String     @default("") // JSON array as string
  body       String     @default("")
  date       String     @default("") // ISO date string
  status     PostStatus @default(PUBLISHED)
  authorId   String?
  authorUser User?      @relation("StoryAuthor", fields: [authorId], references: [id])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([status])
  @@index([authorId])
}

model Achievement {
  id              String   @id @default(uuid())
  alumniName      String
  graduationClass String?
  title           String
  category        String   @default("OTHER")
  description     String   @default("")
  organization    String?
  yearLabel       String?
  status          String   @default("DRAFT")
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@index([sortOrder])
}
