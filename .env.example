# 运行环境
NODE_ENV="development"
PORT="3000"

# 应用地址
SITE_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
SITE_NAME="燕中校友数字母港"

# 数据库
DATABASE_URL="file:./prisma/dev.db"

# 身份认证
# 部署前请替换为足够长的随机密钥。
SESSION_SECRET="replace-with-a-long-random-secret"
# 超级管理员 (Root Admin) 唯一邮箱识别标识（默认值为 yanchuaner@yanchuaner.cn）
ROOT_ADMIN_EMAIL="yanchuaner@yanchuaner.cn"

# 邮件服务（Resend）
RESEND_API_KEY=""
RESEND_FROM_EMAIL="燕中数字母港 <noreply@example.com>"

# 接口限流
REDIS_URL=""

# Upstash Redis 限流（生产推荐）
# 前往 https://console.upstash.com 免费创建 Redis 实例后填入以下两项：
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# 可选：文件上传与备份目录
UPLOAD_DIR=""
BACKUP_DIR=""

# 可选：冒烟测试配置
SMOKE_BASE_URL="http://localhost:3000"
SMOKE_USERNAME=""
SMOKE_PASSWORD=""
