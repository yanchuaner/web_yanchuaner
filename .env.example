# ============================================
# 燕中校友数字母港 — 环境变量配置模板
# ============================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
#
# 注意：Prisma 7.x 通过 prisma.config.ts 读取 DATABASE_URL，
# 不再在 schema.prisma 中硬编码 url 字段。

# --- 运行模式 ---
NODE_ENV="development"
PORT="3000"

# --- 数据库 ---
# SQLite（本地文件模式）
DATABASE_URL="file:./dev.db"

# --- Redis 缓存（可选）---
# 不设置则跳过 Redis 缓存，直接查询数据库
# REDIS_URL="redis://localhost:6379"

# --- 站点配置 ---
SITE_URL="http://localhost:3000"
SITE_NAME="燕中校友数字母港"

# --- 上传与备份目录 ---
# 默认 ./public/uploads
# UPLOAD_DIR="./public/uploads"
# 默认 ./public/uploads/backups
# BACKUP_DIR="./public/uploads/backups"

# --- 普通访问口令 ---
# 口令 SHA256 哈希，生成命令：
#   node -e "const c=require('crypto');console.log(c.createHash('sha256').update('你的口令').digest('hex'))"
ACCESS_PASSWORD_HASH=""
# 明文口令（仅本地调试用）
ACCESS_PASSWORD=""

# --- 后台管理员 ---
ADMIN_USERNAME="admin"
# 密码 SHA256 哈希
ADMIN_PASSWORD_HASH=""

# --- 签名密钥（必填）---
# 用于 HMAC-SHA256 签名 token。生成：
#   openssl rand -hex 32
SESSION_SECRET=""
