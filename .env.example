# 运行环境
NODE_ENV="development"
PORT="3000"

# 应用地址
SITE_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
SITE_NAME="燕中校友数字母港"
# 独立 AI 工作台地址。生产环境应配置为受 HTTPS 保护的专用域名。
AI_WORKSPACE_URL="http://localhost:3001"
API_PLATFORM_URL="http://localhost:3101"
NEXT_PUBLIC_AI_WORKSPACE_URL="http://localhost:3001"
NEXT_PUBLIC_API_PLATFORM_URL="http://localhost:3101"
NEXT_PUBLIC_LAB_URL="http://localhost:3100"

# 数据库
DATABASE_URL="file:./prisma/dev.db"

# 身份认证
# 部署前请替换为足够长的随机密钥。
SESSION_SECRET="replace-with-a-long-random-secret"
# 超级管理员 (Root Admin) 唯一邮箱识别标识（默认值为 yanchuaner@yanchuaner.cn）
ROOT_ADMIN_EMAIL="yanchuaner@yanchuaner.cn"

# 小程序模拟登录仅供本地开发。生产环境即使设为 true 也会被代码硬禁用。
MP_DEV_MOCK_LOGIN_ENABLED="false"
# 允许模拟登录的现有用户 UUID，多个值用英文逗号分隔。
MP_DEV_MOCK_USER_IDS=""

# 微信小程序登录（服务端专用，AppSecret 不得进入小程序包或仓库）
WECHAT_MINIPROGRAM_APP_ID=""
WECHAT_MINIPROGRAM_APP_SECRET=""

# 邮件服务（Resend）
RESEND_API_KEY=""
RESEND_FROM_EMAIL="燕中数字母港 <noreply@example.com>"

# 接口限流
REDIS_URL=""

# 燕中 API OAuth（仅向认证校友开放）
# 客户端密钥应使用 URL-safe 高熵随机值，并与 API 平台的自定义 OAuth 配置一致。
YANCHUANER_OAUTH_CLIENT_ID="api-yanchuaner"
YANCHUANER_OAUTH_CLIENT_SECRET=""
YANCHUANER_OAUTH_REDIRECT_URI="http://localhost:3101/oauth/yanchuaner"
# OIDC 发行者使用浏览器可访问的主站地址；内部地址供 Docker 容器兑换令牌。
YANCHUANER_OAUTH_ISSUER="http://localhost:3000"
YANCHUANER_OAUTH_INTERNAL_URL="http://host.docker.internal:3000"
# Base64 编码的 PKCS#8 RSA 私钥，由集成脚本生成；不得提交真实值。
YANCHUANER_OAUTH_SIGNING_KEY=""

# Open WebUI 过渡客户端。与 API 平台和自主 AI Web 使用不同密钥。
YANCHUANER_AI_OAUTH_CLIENT_ID="ai-yanchuaner"
YANCHUANER_AI_OAUTH_CLIENT_SECRET=""
YANCHUANER_AI_OAUTH_REDIRECT_URI="http://localhost:3001/oauth/oidc/callback"

# 自主燕中 AI Web 客户端。回调地址必须与 AI_WEB_PUBLIC_URL 派生值完全匹配。
YANCHUANER_AI_WEB_OAUTH_CLIENT_ID="ai-web-yanchuaner"
YANCHUANER_AI_WEB_OAUTH_CLIENT_SECRET=""
YANCHUANER_AI_WEB_OAUTH_REDIRECT_URI="http://localhost:3002/api/auth/callback"

# Upstash Redis 限流（生产推荐）
# 前往 https://console.upstash.com 免费创建 Redis 实例后填入以下两项：
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# 可选：文件上传与备份目录
UPLOAD_DIR=""
BACKUP_DIR=""

# 可选：冒烟测试配置
SMOKE_BASE_URL="http://localhost:3000"
SMOKE_USERNAME=""
SMOKE_PASSWORD=""
