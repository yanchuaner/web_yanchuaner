# ============================================
# 燕川校友数字母港 — 环境变量配置模板
# ============================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# --- 数据库 ---
# SQLite (本地文件模式，适合单机部署)
DATABASE_URL="file:./dev.db"

# 如果切换为 PostgreSQL（推荐多实例/云部署）:
# DATABASE_URL="postgresql://user:password@host:5432/yanchuan_alumni?schema=public"

# --- Redis 缓存（可选）---
# 不设置则跳过 Redis 缓存，直接查询数据库
# REDIS_URL="redis://localhost:6379"

# --- 访问口令（服务端验证，不暴露给客户端）---
# 校友网站入口口令，由 /api/auth/verify 服务端验证
ACCESS_PASSWORD="iloveyanchuan!"
# 生产环境请务必修改此口令！
# 旧版 NEXT_PUBLIC_ACCESS_HASH 已废弃，口令不再写死在客户端代码中

# --- 站点配置 ---
SITE_URL="https://yanchuaner.cn"
SITE_NAME="燕川校友数字母港"
