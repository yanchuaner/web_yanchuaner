{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run start)",
      "Bash(npm run lint)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx next lint*)",
      "Bash(npx prisma generate)",
      "Bash(npx prisma db push)",
      "Bash(npx prisma studio)",
      "Bash(git status*)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "WebFetch(domain:localhost)"
    ]
  }
}
