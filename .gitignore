.env
.env.*
!.env.example
!.env.staging.example
.env.bak.*

# Local credential rotation file (real values; never commit)
credentials.local.json

# Build output
.next/
*.tsbuildinfo
deploy/
dist/

# Development database
# 用通配规则兜底，杜绝任何 SQLite 文件（含历史误命名的备份）被提交
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
dev.db
dev.db-shm
dev.db-wal
prod.db-shm
prod.db-wal

# Editor tooling
.opencode/
.vscode/
.idea/
AGENTS.md

# Generated code
/src/generated/prisma

# Claude Code: ignore local/personal config & work artifacts,
# but share the project-level settings.json with the team.
.claude/*
!.claude/settings.json

# Production data (never commit)
prod.db
public/uploads/
/data/
/data/backups/
alumni_roster.csv
source_alumni.json

