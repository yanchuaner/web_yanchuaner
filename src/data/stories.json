[
  {
    "id": "story-major-truth-001",
    "title": "\u300a\u4e13\u4e1a\u771f\u76f8\uff1a\u5199\u4ee3\u7801\u4e4b\u524d\uff0c\u5148\u5b66\u4f1a\u63d0\u95ee\u300b",
    "author": "\u9ec4\u540c\u5b66\u00b7 2022\u7ea71\u73ed",
    "tags": ["\u4e13\u4e1a\u771f\u76f8", "\u907f\u5751\u6307\u5357"],
    "body": "\u5927\u4e00\u65b0\u751f\u5f88\u5bb9\u6613\u8bef\u4ee5\u4e3a\u201c\u8bfe\u7a0b\u96be\u201d\u662f\u6700\u5927\u6311\u6218\uff0c\u5176\u5b9e\u66f4\u96be\u7684\u662f\u4ece\u201c\u88ab\u52a8\u505a\u9898\u201d\u5207\u6362\u5230\u201c\u4e3b\u52a8\u5b9a\u4e49\u95ee\u9898\u201d\u3002\u5efa\u8bae\u5b66\u5f1f\u5b66\u59b9\u63d0\u524d\u7ec3\u4e60\u9ad8\u8d28\u91cf\u68c0\u7d22\u3001\u8bfb\u6587\u6863\u548c\u62c6\u5206\u9700\u6c42\uff0c\u8fd9\u4f1a\u8ba9\u4f60\u7684\u9879\u76ee\u6548\u7387\u76f4\u63a5\u63d0\u5347\u4e00\u500d\u3002",
    "date": "2026-03-18"
  },
  {
    "id": "story-campus-memory-002",
    "title": "\u300a\u6821\u56ed\u56de\u5fc6\uff1a\u665a\u81ea\u4e60\u505c\u7535\u90a3\u665a\uff0c\u6211\u4eec\u628a\u9752\u6625\u5199\u8fdb\u8d70\u5eca\u300b",
    "author": "\u5434\u540c\u5b66\u00b7 2022\u7ea717\u73ed",
    "tags": ["\u6821\u56ed\u56de\u5fc6", "\u9752\u6625\u5bc4\u8bed"],
    "body": "\u90a3\u5929\u505c\u7535\u540e\uff0c\u6574\u680b\u697c\u53ea\u5269\u4e0b\u624b\u7535\u7b52\u548c\u661f\u5149\u3002\u6211\u4eec\u56f4\u5728\u8d70\u5eca\u5c3d\u5934\u80cc\u82f1\u8bed\u3001\u80cc\u5730\u7406\uff0c\u4e5f\u8bb2\u8d77\u201c\u5341\u5e74\u540e\u4f60\u60f3\u6210\u4e3a\u8c01\u201d\u3002\u73b0\u5728\u56de\u770b\uff0c\u90a3\u4e0d\u4ec5\u662f\u5907\u8003\u591c\uff0c\u66f4\u662f\u6211\u4eec\u5171\u540c\u8d77\u98de\u7684\u8d77\u70b9\u3002",
    "date": "2026-03-26"
  },
  {
    "id": "story-major-truth-003",
    "title": "\u300a\u4e13\u4e1a\u771f\u76f8\uff1a\u70ed\u95e8\u4e13\u4e1a\u4e0d\u7b49\u4e8e\u9002\u5408\u4f60\u300b",
    "author": "\u6768\u540c\u5b66\u00b7 2022\u7ea714\u73ed",
    "tags": ["\u4e13\u4e1a\u771f\u76f8", "\u907f\u5751\u6307\u5357"],
    "body": "\u586b\u62a5\u5fd7\u613f\u65f6\uff0c\u6211\u4eec\u6700\u5bb9\u6613\u88ab\u201c\u5c31\u4e1a\u7387\u3001\u8d5a\u94b1\u5feb\u201d\u5e26\u504f\u3002\u4f46\u771f\u6b63\u80fd\u8dd1\u8fdc\u7684\uff0c\u662f\u201c\u5174\u8da3 + \u80fd\u529b + \u6027\u683c\u201d\u7684\u4ea4\u96c6\u3002\u5efa\u8bae\u5148\u505a 3 \u4ef6\u4e8b\uff1a\u627e\u5b66\u957f\u8bbf\u8c08\u3001\u770b\u8bfe\u8868\u3001\u8bd5\u505a\u4e00\u4e2a\u5c0f\u9879\u76ee\u3002\u4e0d\u8ddf\u98ce\uff0c\u4f60\u624d\u80fd\u8d70\u5f97\u66f4\u7a33\u3002",
    "date": "2026-04-01"
  }
]
